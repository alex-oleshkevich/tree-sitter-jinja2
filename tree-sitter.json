{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "jinja2",
      "camelcase": "Jinja2",
      "title": "Jinja2",
      "scope": "source.jinja2",
      "file-types": [
        "jinja2",
        "html.j2",
        "js.j2",
        "jinja",
        "css.j2",
        "j2",
        "yaml.j2",
        "yml.j2"
      ],
      "injection-regex": "^jinja2$",
      "class-name": "TreeSitterJinja2"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Jinja grammar for tree-sitter",
    "authors": [
      {
        "name": "Alex Oleshkevich",
        "email": "alex.oleshkevich@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-jinja2"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
